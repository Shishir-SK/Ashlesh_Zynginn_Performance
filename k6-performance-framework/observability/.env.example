# Observability Environment Configuration
# Add these to your existing .env or export before running tests

# InfluxDB Configuration
K6_OUT=influxdb=http://localhost:8086/k6-bucket
K6_INFLUXDB_ORGANIZATION=k6-org
K6_INFLUXDB_TOKEN=adminpassword
K6_INFLUXDB_PUSH_INTERVAL=1s

# Grafana URLs (for reference)
GRAFANA_URL=http://localhost:3000
INFLUXDB_URL=http://localhost:8086

# Dashboard auto-refresh (seconds)
GRAFANA_REFRESH_INTERVAL=5

# Data retention (days)
INFLUXDB_RETENTION=7
